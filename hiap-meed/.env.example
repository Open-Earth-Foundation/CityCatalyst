# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
ARTIFACT_LOG_JSONL=true
# When falsey, disables writing `LOG_DIR/app.log` (keeps console logging).
# Useful for tests to avoid polluting runtime logs.
LOG_FILE_ENABLED=true
# output folder for file logs and request artifacts
LOG_DIR=logs

# shared upstream HTTP client runtime config
UPSTREAM_HTTP_TIMEOUT_SECONDS=30
UPSTREAM_HTTP_MAX_RETRIES=2
UPSTREAM_HTTP_RETRY_BACKOFF_SECONDS=0.5

# shared Global API host used by upstream API-backed clients
CCGLOBAL_API_BASE_URL=https://ccglobal.openearth.dev

# city data source: mock | api
HIAP_MEED_CITY_DATA_SOURCE=api

# legal hard-filter data source: mock | api
HIAP_MEED_LEGAL_DATA_SOURCE=mock

# action catalog source: mock | api
HIAP_MEED_ACTION_DATA_SOURCE=mock

# policy signals source: mock | api
HIAP_MEED_POLICY_SIGNALS_DATA_SOURCE=mock

# default number of ranked actions returned when request cityDataList item has no topN override
HIAP_MEED_TOP_N=20

# guarded future activity-data-level mapping step inside Impact
ACTIVITY_DATA_LEVEL_MAPPING=false

# alignment other-preference LLM mapping runtime config
# model used by alignment free-text -> co-benefit mapping
HIAP_MEED_ALIGNMENT_OTHER_PREFERENCE_MODEL=

# exclusion preview free-text resolver runtime config
# set to true to call the LLM resolver for excludedActionsFreeText in preview API
HIAP_MEED_FREE_TEXT_EXCLUSIONS_ENABLED=false
# model used by preview free-text -> action ID matching
HIAP_MEED_FREE_TEXT_EXCLUSIONS_MODEL=

# explanation stage runtime config
# set to false to disable explanation calls globally, even if requestData.createExplanations=true
HIAP_MEED_EXPLANATIONS_ENABLED=true
# model name used by the explanation stage
HIAP_MEED_EXPLANATIONS_MODEL=
# model name used for explanation translation
HIAP_MEED_EXPLANATION_TRANSLATIONS_MODEL=

# required for OpenAI-backed features
OPENAI_API_KEY=
# shared OpenAI client timeout in seconds
OPENAI_TIMEOUT_SECONDS=30
# shared OpenAI client retries
OPENAI_MAX_RETRIES=3


