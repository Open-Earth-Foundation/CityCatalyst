# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
ARTIFACT_LOG_JSONL=true
# When falsey, disables writing `LOG_DIR/app.log` (keeps console logging).
# Useful for tests to avoid polluting runtime logs.
LOG_FILE_ENABLED=true
# output folder for file logs and request artifacts
LOG_DIR=logs

# city data source: mock | api
HIAP_MEED_CITY_DATA_SOURCE=mock

# legal hard-filter data source: mock | api
HIAP_MEED_LEGAL_DATA_SOURCE=mock

# action catalog source: mock | api
HIAP_MEED_ACTION_DATA_SOURCE=mock

# policy signals source: mock | api
HIAP_MEED_POLICY_SIGNALS_DATA_SOURCE=mock

# default number of ranked actions returned when request cityDataList item has no topN override
HIAP_MEED_TOP_N=20

# explanation stage runtime config
# set to false to disable explanation calls globally, even if requestData.createExplanations=true
HIAP_MEED_EXPLANATIONS_ENABLED=true
# model name used by the explanation stage
HIAP_MEED_EXPLANATIONS_MODEL=
# per-request timeout in seconds for explanation generation
HIAP_MEED_EXPLANATIONS_TIMEOUT_SECONDS=30
# retries for explanation provider client calls
HIAP_MEED_EXPLANATIONS_MAX_RETRIES=1

# required for explanation generation
OPENAI_API_KEY=


