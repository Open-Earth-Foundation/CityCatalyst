# Climate Advisor Service configuration
OPENROUTER_API_KEY=sk-or-placeholder
# Default OpenRouter routing. Set to https://api.openai.com/v1 for direct OpenAI chat routing.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Provider-prefixed model IDs (for example openai/gpt-4.1) are normalized automatically for direct OpenAI routing.
OPENROUTER_MODEL=openai/gpt-oss-120b
# Optional override for bounded agentic flows such as Stationary Energy draft chat.
OPENROUTER_AGENTIC_FLOW_MODEL=openai/gpt-oss-120b
OPENROUTER_TIMEOUT_MS=30000
OPENROUTER_MAX_RETRIES=3
REQUEST_TIMEOUT_MS=30000
CA_CORS_ORIGINS=*
CA_FEATURE_FLAGS=

# Postgres persistence configuration
# Default host-facing CA DB URL. Use localhost:5433 to avoid conflict with
# local CityCatalyst Postgres typically running on localhost:5432.
CA_DATABASE_URL=postgresql://climateadvisor:climateadvisor@localhost:5433/climateadvisor
CA_DATABASE_POOL_SIZE=5
CA_DATABASE_MAX_OVERFLOW=10
CA_DATABASE_POOL_TIMEOUT=30
CA_DATABASE_ECHO=false

# CityCatalyst Integration
CC_API_KEY=your-cc-service-api-key-here
CC_BASE_URL=http://localhost:3000
