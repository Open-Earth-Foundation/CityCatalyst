# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
LOCAL_ARTIFACTS_ENABLED=true
# When falsey, disables writing `LOG_DIR/app.log` (keeps console logging).
# Useful for tests to avoid polluting runtime logs.
LOG_FILE_ENABLED=true
# output folder for app.log and optional local request artifacts
LOG_DIR=logs
##
# Standard CityCatalyst setup:
# - point services and local runs to the hosted dev MLflow by default
# - use MLFLOW_ENVIRONMENT to distinguish dev, test, and prod runs
#
# Fully local MLflow via Docker Compose:
# - run `docker compose up --build`
# - override MLFLOW_TRACKING_URI=http://mlflow:5000
#
# Laptop run against Kubernetes-hosted MLflow via port-forward:
# - override MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ENABLED=true
MLFLOW_TRACKING_URI=https://mlflow-dev.openearth.dev
# Non-admin MLflow service account credentials; never commit real values.
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
MLFLOW_EXPERIMENT_NAME=hiap-meed
MLFLOW_ENVIRONMENT=dev
# fail fast when the tracking URL is wrong or unreachable; request-time retries
# are handled separately by the application cooldown
MLFLOW_HTTP_REQUEST_TIMEOUT=3
MLFLOW_HTTP_REQUEST_MAX_RETRIES=1
MLFLOW_HTTP_REQUEST_BACKOFF_FACTOR=1
MLFLOW_HTTP_REQUEST_BACKOFF_JITTER=0
# suppress mlflow related GitPython warnings when the hiap-meed process/container has no git executable; this does not restore git SHA capture
GIT_PYTHON_REFRESH=quiet
# when true, MLflow tags/params/metrics use async fluent logging; run open/close and artifacts stay sync
MLFLOW_ASYNC_LOGGING_ENABLED=true
# test-only endpoint for forcing a simple OpenAI tool-calling trace into MLflow
HIAP_MEED_MLFLOW_TOOL_TRACE_TEST_ENABLED=false
HIAP_MEED_MLFLOW_TOOL_TRACE_TEST_MODEL=gpt-5.4-mini

# shared upstream HTTP client runtime config
UPSTREAM_HTTP_TIMEOUT_SECONDS=30
UPSTREAM_HTTP_MAX_RETRIES=2
UPSTREAM_HTTP_RETRY_BACKOFF_SECONDS=0.5

# shared Global API host used by upstream API-backed clients
CCGLOBAL_API_BASE_URL=https://ccglobal.openearth.dev

# city data source: mock | api
HIAP_MEED_CITY_DATA_SOURCE=api

# legal hard-filter data source: s3 | mock | api (api is deprecated and fails)
HIAP_MEED_LEGAL_DATA_SOURCE=s3
HIAP_MEED_LEGAL_S3_BUCKET=test-global-api
HIAP_MEED_LEGAL_S3_KEY=raw_data/cl_ssg/cl_ssg_legal_signals/release/v2/legal-classification-v2.csv
HIAP_MEED_LEGAL_S3_REGION=us-east-1
# Required only for explicit live S3 external tests or deployments that do not use IAM/workload identity.
# The tests intentionally ignore local AWS CLI profiles.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# action pathways source: mock | api
HIAP_MEED_ACTION_PATHWAYS_DATA_SOURCE=api

# action policy scores source: mock | api
HIAP_MEED_ACTION_POLICY_SCORES_DATA_SOURCE=api

# action mitigation feasibility scores source: mock | api
HIAP_MEED_ACTION_MITIGATION_FEASIBILITY_SCORES_DATA_SOURCE=api

# action financial feasibility scores source: mock | api
HIAP_MEED_ACTION_FINANCIAL_FEASIBILITY_SCORES_DATA_SOURCE=api

# default number of ranked actions returned when request cityDataList item has no topN override
HIAP_MEED_TOP_N=20

# guarded future activity-data-level mapping step inside Impact
ACTIVITY_DATA_LEVEL_MAPPING=false

# required for OpenAI-backed features
OPENAI_API_KEY=


