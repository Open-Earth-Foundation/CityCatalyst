# Files / dirs Cursor should NOT index for embeddings or context.
# Keep this short — narrower index = faster, more focused agents.

# Build artifacts
**/.next/
**/dist/
**/build/
**/out/

# Dependencies
**/node_modules/
**/.venv/
**/venv/
**/uv.lock

# Generated
**/coverage/
**/playwright-report/
**/test-results/
**/openapi-spec.json

# Heavy data / fixtures
**/*.gpkg
**/*.parquet
**/*.csv
**/*.geojson
load-test/**/*.csv

# Local secrets and env
.env
.env.local
.env.*.local
**/credentials*.json
**/*.pem

# Logs
**/logs/
**/*.log

# Lockfiles (large, rarely useful in context)
package-lock.json
yarn.lock
pnpm-lock.yaml
poetry.lock

# Big SVGs / images
docs/*.svg
**/public/images/large/**

# Translations (auto-generated; see web-translate.yml)
app/src/i18n/locales/de/**
app/src/i18n/locales/es/**
app/src/i18n/locales/fr/**
app/src/i18n/locales/pt/**
